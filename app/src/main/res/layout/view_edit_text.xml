<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/squircle_text_field">

        <EditText
            android:id="@+id/innerEditText"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="#00000000"
            android:drawableStart="@drawable/user"
            android:drawablePadding="8dp"
            android:hint="@string/enter_your_email_or_username"
            android:paddingHorizontal="16dp"
            android:textColor="@color/shade_primary"
            android:textColorHint="@color/shade_tertiary"
            android:textSize="@dimen/text_size_body_md" />

        <ImageView
            android:id="@+id/passwordEye"
            android:layout_width="48dp"
            android:adjustViewBounds="false"
            android:layout_height="48dp"
            android:background="@drawable/click_ripple"
            android:clickable="true"
            android:focusable="true"
            android:padding="14dp"
            android:src="@drawable/eye_opened" />
    </LinearLayout>

    <TextView
        android:id="@+id/helperText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/additional_primary_red"
        android:textSize="@dimen/text_size_body_sm" />
</LinearLayout>