<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="shapableCorner16dp">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- FONT WEIGHT BASES -->
    <style name="Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
    </style>

    <style name="Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
    </style>

    <style name="SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
    </style>

    <style name="Bold">
        <item name="android:fontFamily">@font/manrope_bold</item>
    </style>

    <!-- TEXT STYLES -->

    <!-- Display -->
    <style name="Bold.TextDisplayXL">
        <item name="android:textSize">@dimen/text_size_display_xl</item>
    </style>

    <!-- Title -->
    <style name="Medium.TextTitleXL">
        <item name="android:textSize">@dimen/text_size_title_xl</item>
    </style>

    <style name="Medium.TextTitleLG">
        <item name="android:textSize">@dimen/text_size_title_lg</item>
    </style>

    <style name="Medium.TextTitleMD">
        <item name="android:textSize">@dimen/text_size_title_md</item>
    </style>

    <style name="Medium.TextTitleSM">
        <item name="android:textSize">@dimen/text_size_title_sm</item>
    </style>

    <!-- Body LG -->
    <style name="Regular.TextBodyLG">
        <item name="android:textSize">@dimen/text_size_body_lg</item>
    </style>

    <style name="Medium.TextBodyLG">
        <item name="android:textSize">@dimen/text_size_body_lg</item>
    </style>

    <style name="SemiBold.TextBodyLG">
        <item name="android:textSize">@dimen/text_size_body_lg</item>
    </style>

    <!-- Body MD -->
    <style name="Regular.TextBodyMD">
        <item name="android:textSize">@dimen/text_size_body_md</item>
    </style>

    <style name="Medium.TextBodyMD">
        <item name="android:textSize">@dimen/text_size_body_md</item>
    </style>

    <style name="SemiBold.TextBodyMD">
        <item name="android:textSize">@dimen/text_size_body_md</item>
    </style>

    <!-- Body SM -->
    <style name="Regular.TextBodySM">
        <item name="android:textSize">@dimen/text_size_body_sm</item>
    </style>

    <style name="Medium.TextBodySM">
        <item name="android:textSize">@dimen/text_size_body_sm</item>
    </style>

    <style name="SemiBold.TextBodySM">
        <item name="android:textSize">@dimen/text_size_body_sm</item>
    </style>

    <!-- Label MD -->
    <style name="Regular.TextLabelMD">
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>

    <style name="Medium.TextLabelMD">
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>

    <style name="SemiBold.TextLabelMD">
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>


    <style name="SquircleButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/squircle_button_background</item>
        <item name="android:textColor">@color/button_on_primary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="SquircleButton.Secondary">
        <item name="android:background">@drawable/squircle_button_background_secondary</item>
        <item name="android:textColor">@color/shade_secondary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="SquircleButton.Regular">
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>

    <style name="SquircleButton.Medium">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>

    <style name="SquircleButton.SemiBold">
        <item name="android:fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>

    <style name="SquircleButton.Bold">
        <item name="android:fontFamily">@font/manrope_bold</item>
        <item name="android:textSize">@dimen/text_size_label_md</item>
    </style>

</resources>